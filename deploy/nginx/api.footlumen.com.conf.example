# Example Nginx reverse proxy for api.footlumen.com.
# Enable after TLS is configured. Rate limiting is intentionally handled here.

limit_req_zone $binary_remote_addr zone=footlumen_api:10m rate=30r/m;

server {
    listen 80;
    server_name api.footlumen.com;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name api.footlumen.com;

    ssl_certificate /etc/letsencrypt/live/api.footlumen.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.footlumen.com/privkey.pem;

    client_max_body_size 1m;

    location / {
        limit_req zone=footlumen_api burst=20 nodelay;

        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        proxy_connect_timeout 5s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;
    }
}
